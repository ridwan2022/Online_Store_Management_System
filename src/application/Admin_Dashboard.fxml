<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<AnchorPane prefHeight="607.0" prefWidth="675.0" styleClass="anchor-pane" stylesheets="@application.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.adminController">
    <Label layoutX="204.0" layoutY="81.0" text="Admin Dashboard" textFill="WHITE">
      <font>
         <Font size="30.0" />
      </font></Label>
   <Button fx:id="putItemOnSale" layoutX="251.0" layoutY="330.0" mnemonicParsing="false" onAction="#handleSale" prefHeight="44.0" prefWidth="173.0" styleClass="rounded-button" text="Put item on sale" textAlignment="CENTER" textFill="WHITE">
      <font>
         <Font size="20.0" />
      </font>
   </Button>
   <Button fx:id="viewAllProducts" layoutX="229.0" layoutY="178.0" mnemonicParsing="false" onAction="#viewProducts" prefHeight="39.0" prefWidth="201.0" styleClass="rounded-button" stylesheets="@application.css" text="View List of Products">
      <font>
         <Font size="18.0" />
      </font></Button>
   <Button layoutX="73.0" layoutY="516.0" mnemonicParsing="false" onAction="#backToWelcome" prefHeight="39.0" prefWidth="72.0" styleClass="rounded-button" text="Back">
      <font>
         <Font size="20.0" />
      </font>
   </Button>
   <Button layoutX="247.0" layoutY="256.0" mnemonicParsing="false" onAction="#addNewProduct" styleClass="rounded-button" text="Add Item to Store" />
</AnchorPane>
